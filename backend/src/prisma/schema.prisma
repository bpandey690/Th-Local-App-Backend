generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Ride {
  id              String                   @id @default(dbgenerated("(gen_random_uuid())::text"))
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  driverId        String
  seatsAvailable  Int                      @default(1)
  chargeCents     Int
  startTime       DateTime
  endTime         DateTime
  startPlaceName  String
  endPlaceName    String
  startPoint      Unsupported("geometry")?
  endPoint        Unsupported("geometry")?
  routeLine       Unsupported("geometry")?
  status          RideStatus               @default(OPEN)
  vehicleType     String                   @default("CAR")
  vehicleCapacity Int                      @default(5)
  fuelType        String                   @default("Petrol")
  vehicleNumber   String                   @default("")
  driver          User                     @relation("DriverRides", fields: [driverId], references: [id], onUpdate: NoAction)
  requests        RideRequest[]

  @@index([startTime])
  @@index([endTime])
}

model RideRequest {
  id             String                   @id @default(dbgenerated("(gen_random_uuid())::text"))
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  rideId         String
  riderId        String
  riderStartName String
  riderEndName   String
  riderStartTime DateTime
  riderStart     Unsupported("geometry")?
  riderEnd       Unsupported("geometry")?
  status         RideStatus               @default(REQUESTED)
  fareCents      Int                      @default(1000)
  ride           Ride                     @relation(fields: [rideId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  rider          User                     @relation("RiderRequests", fields: [riderId], references: [id], onUpdate: NoAction)

  @@index([rideId])
}

model User {
  id               String            @id @default(dbgenerated("(gen_random_uuid())::text"))
  email            String?           @unique
  name             String
  firebaseUid      String            @unique
  phoneNumber      String?           @unique
  profilePic       String?
  passwordHash     String?
  role             String            @default("passenger")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  gender           String?
  fcmToken         String?
  bookings         Booking[]
  cart             Cart?
  follows          Follow[]
  messages         Message[]
  orders           Order[]
  parkingBookings  ParkingBooking[]  @relation("UserParkingBookings")
  parkingSpots     ParkingSpot[]     @relation("OwnerParkingSpots")
  ridesAsDriver    Ride[]            @relation("DriverRides")
  rideRequests     RideRequest[]     @relation("RiderRequests")
  serviceProviders ServiceProvider[]
  shops            Shop[]
  vehicle          Vehicle?
}

model Message {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  chatId    String
  text      String
  createdAt DateTime @default(now())
  senderId  String
  status    String   @default("SENT")
  sender    User     @relation(fields: [senderId], references: [id], onUpdate: NoAction)

  @@index([chatId])
}

model Shop {
  id          String        @id @default(dbgenerated("(gen_random_uuid())::text"))
  ownerId     String
  name        String
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  owner       User          @relation(fields: [ownerId], references: [id], onUpdate: NoAction)
  products    ShopProduct[]
}

model Product {
  id           String        @id @default(dbgenerated("(gen_random_uuid())::text"))
  name         String
  description  String?
  imageUrl     String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  shopProducts ShopProduct[]
}

model ShopProduct {
  id         String      @id @default(dbgenerated("(gen_random_uuid())::text"))
  shopId     String
  productId  String
  price      Float
  stock      Int         @default(0)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  cartItems  CartItem[]
  orderItems OrderItem[]
  product    Product     @relation(fields: [productId], references: [id], onUpdate: NoAction)
  shop       Shop        @relation(fields: [shopId], references: [id], onUpdate: NoAction)

  @@unique([shopId, productId])
}

model Cart {
  id        String     @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId    String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onUpdate: NoAction)
  items     CartItem[]
}

model CartItem {
  id            String      @id @default(dbgenerated("(gen_random_uuid())::text"))
  cartId        String
  shopProductId String
  quantity      Int         @default(1)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  cart          Cart        @relation(fields: [cartId], references: [id], onUpdate: NoAction)
  shopProduct   ShopProduct @relation(fields: [shopProductId], references: [id], onUpdate: NoAction)
}

model Order {
  id          String      @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId      String
  totalAmount Float
  status      OrderStatus @default(PENDING)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        User        @relation(fields: [userId], references: [id], onUpdate: NoAction)
  items       OrderItem[]
}

model OrderItem {
  id            String      @id @default(dbgenerated("(gen_random_uuid())::text"))
  orderId       String
  shopProductId String
  quantity      Int
  priceAtTime   Float
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  order         Order       @relation(fields: [orderId], references: [id], onUpdate: NoAction)
  shopProduct   ShopProduct @relation(fields: [shopProductId], references: [id], onUpdate: NoAction)
}

model ServiceProvider {
  id               String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  ownerId          String
  name             String
  services         String?
  rating           Float     @default(5.0)
  ratingCount      Int       @default(1)
  dist             String?   @default("0.5 km")
  emoji            String?   @default("🛠️")
  bg               String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  providedServices Service[]
  owner            User      @relation(fields: [ownerId], references: [id], onUpdate: NoAction)
}

model Service {
  id          String          @id @default(dbgenerated("(gen_random_uuid())::text"))
  providerId  String
  name        String
  price       Float
  description String?
  rating      Float           @default(5.0)
  emoji       String?         @default("🛠️")
  category    String
  bg          String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  bookings    Booking[]
  provider    ServiceProvider @relation(fields: [providerId], references: [id], onUpdate: NoAction)
}

model Booking {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId    String
  serviceId String
  timeSlot  String
  date      String   @default("Today")
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  service   Service  @relation(fields: [serviceId], references: [id], onUpdate: NoAction)
  user      User     @relation(fields: [userId], references: [id], onUpdate: NoAction)
}

model Follow {
  id         String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId     String
  businessId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onUpdate: NoAction)

  @@unique([userId, businessId])
}

model ParkingSpot {
  id             String                @id @default(dbgenerated("(gen_random_uuid())::text"))
  spotName       String                @unique
  level          Int
  section        String
  row            Int
  col            Int
  ownerId        String?
  approved       Boolean               @default(false)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  priceHourly    Float                 @default(50)
  priceDaily     Float                 @default(100)
  priceWeekly    Float                 @default(500)
  priceMonthly   Float                 @default(1000)
  availabilities ParkingAvailability[]
  bookings       ParkingBooking[]
  owner          User?                 @relation("OwnerParkingSpots", fields: [ownerId], references: [id], onUpdate: NoAction)
}

model ParkingAvailability {
  id        String           @id @default(dbgenerated("(gen_random_uuid())::text"))
  spotId    String
  date      String
  slotType  ParkingSlotType  @default(HOURLY)
  startTime DateTime
  endTime   DateTime
  price     Float
  isBooked  Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  spot      ParkingSpot      @relation(fields: [spotId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  bookings  ParkingBooking[]
}

model ParkingBooking {
  id             String               @id @default(dbgenerated("(gen_random_uuid())::text"))
  spotId         String
  availabilityId String?
  userId         String
  date           String
  slotType       ParkingSlotType
  startTime      DateTime
  endTime        DateTime
  price          Float
  status         BookingStatus        @default(REQUESTED)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  availability   ParkingAvailability? @relation(fields: [availabilityId], references: [id], onUpdate: NoAction)
  spot           ParkingSpot          @relation(fields: [spotId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user           User                 @relation("UserParkingBookings", fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model Vehicle {
  id            String   @id @default(uuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  userId        String   @unique
  vehicleNumber String
  type          String
  capacity      Int
  fuelType      String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationCode {
  id          String   @id @default(uuid())
  phoneNumber String
  code        String
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([phoneNumber])
}

model PendingNotification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  payload   String
  createdAt DateTime @default(now())

  @@index([userId])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model spatial_ref_sys {
  srid      Int     @id
  auth_name String? @db.VarChar(256)
  auth_srid Int?
  srtext    String? @db.VarChar(2048)
  proj4text String? @db.VarChar(2048)
}

enum RideStatus {
  OPEN
  REQUESTED
  ACCEPTED
  REJECTED
  CANCELLED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  REJECTED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum ParkingSlotType {
  HOURLY
  DAILY
  WEEKLY
  MONTHLY
}

enum BookingStatus {
  REQUESTED
  ACCEPTED
  REJECTED
  CANCELLED
}
