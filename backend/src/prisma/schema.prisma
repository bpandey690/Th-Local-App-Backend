generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum RideStatus {
  OPEN
  REQUESTED
  ACCEPTED
  REJECTED
  CANCELLED
}

model Ride {
  id                String     @id @default(uuid())
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  driverId          String
  driver            User       @relation("DriverRides", fields: [driverId], references: [id])
  seatsAvailable    Int        @default(1)
  chargeCents       Int

  startTime         DateTime
  endTime           DateTime

  startPlaceName    String
  endPlaceName      String

  // PostGIS geometry (SRID 4326) stored as:
  // - startPoint/endPoint: POINT
  // - routeLine: LINESTRING
  startPoint        Unsupported("geometry(Point,4326)")?
  endPoint          Unsupported("geometry(Point,4326)")?
  routeLine         Unsupported("geometry(LineString,4326)")?

  status            RideStatus @default(OPEN)

  vehicleType       String     @default("CAR")
  vehicleCapacity   Int        @default(5)
  fuelType          String     @default("Petrol")
  vehicleNumber     String     @default("")

  requests          RideRequest[]

  @@index([startTime])
  @@index([endTime])
}

model RideRequest {
  id             String   @id @default(uuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  rideId         String
  ride           Ride     @relation(fields: [rideId], references: [id], onDelete: Cascade)

  riderId        String
  rider          User     @relation("RiderRequests", fields: [riderId], references: [id])
  riderStartName String
  riderEndName   String
  riderStartTime DateTime

  riderStart     Unsupported("geometry(Point,4326)")?
  riderEnd       Unsupported("geometry(Point,4326)")?

  status         RideStatus @default(REQUESTED)
  fareCents      Int        @default(1000)

  @@index([rideId])
}

model User {
  id            String        @id @default(uuid())
  email         String?       @unique
  name          String
  firebaseUid   String        @unique
  phoneNumber   String?       @unique
  profilePic    String?
  passwordHash  String?
  role          String        @default("passenger")
  gender        String?
  fcmToken      String?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // A user can post many rides (as a driver)
  ridesAsDriver Ride[]        @relation("DriverRides")

  // A user can request many rides (as a rider)
  rideRequests  RideRequest[] @relation("RiderRequests")

  buddyRequests BuddyRequest[] @relation("RiderBuddyRequests")

  // Messages sent by this user
  messages      Message[]

  shops            Shop[]
  serviceProviders ServiceProvider[]
  bookings         Booking[]
  cart          Cart?
  orders        Order[]
  follows       Follow[]

  // Parking relations
  parkingSpots    ParkingSpot[]    @relation("OwnerParkingSpots")
  parkingBookings ParkingBooking[] @relation("UserParkingBookings")

  vehicle       Vehicle?
}

model Message {
  id        String   @id @default(uuid())
  chatId    String   // rideId:userId or similar
  text      String
  status    String   @default("SENT") // SENT, DELIVERED, READ
  createdAt DateTime @default(now())

  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])

  @@index([chatId])
}

model Shop {
  id          String   @id @default(uuid())
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id])
  name        String
  description String?
  products    ShopProduct[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String?
  imageUrl    String?
  shopProducts ShopProduct[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ShopProduct {
  id          String   @id @default(uuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id])
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  price       Float
  stock       Int      @default(0)
  cartItems   CartItem[]
  orderItems  OrderItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([shopId, productId])
}

model Cart {
  id          String     @id @default(uuid())
  userId      String     @unique
  user        User       @relation(fields: [userId], references: [id])
  items       CartItem[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model CartItem {
  id            String      @id @default(uuid())
  cartId        String
  cart          Cart        @relation(fields: [cartId], references: [id])
  shopProductId String
  shopProduct   ShopProduct @relation(fields: [shopProductId], references: [id])
  quantity      Int         @default(1)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Order {
  id          String      @id @default(uuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  totalAmount Float
  status      OrderStatus @default(PENDING)
  items       OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

enum OrderStatus {
  PENDING
  CONFIRMED
  REJECTED
  SHIPPED
  DELIVERED
  CANCELLED
}

model OrderItem {
  id            String      @id @default(uuid())
  orderId       String
  order         Order       @relation(fields: [orderId], references: [id])
  shopProductId String
  shopProduct   ShopProduct @relation(fields: [shopProductId], references: [id])
  quantity      Int
  priceAtTime   Float
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model ServiceProvider {
  id          String    @id @default(uuid())
  ownerId     String
  owner       User      @relation(fields: [ownerId], references: [id])
  name        String
  services    String?
  rating      Float     @default(5.0)
  ratingCount Int       @default(1)
  dist        String?   @default("0.5 km")
  emoji       String?   @default("🛠️")
  bg          String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  providedServices Service[]
}

model Service {
  id          String    @id @default(uuid())
  providerId  String
  provider    ServiceProvider @relation(fields: [providerId], references: [id])
  name        String
  price       Float
  description String?
  rating      Float     @default(5.0)
  emoji       String?   @default("🛠️")
  category    String
  bg          String?
  bookings    Booking[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Booking {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  serviceId   String
  service     Service   @relation(fields: [serviceId], references: [id])
  timeSlot    String
  date        String    @default("Today")
  status      String    @default("PENDING")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Follow {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  businessId String   // shopId or providerId
  createdAt  DateTime @default(now())

  @@unique([userId, businessId])
}

// ==========================================
// Parking Reservation System Models
// ==========================================

enum ParkingSlotType {
  HOURLY
  DAILY
  WEEKLY
  MONTHLY
}

enum BookingStatus {
  REQUESTED
  ACCEPTED
  REJECTED
  CANCELLED
}

model ParkingSpot {
  id             String                @id @default(uuid())
  spotName       String                @unique
  level          Int                   // 1 to 5
  section        String                // "LEFT", "MIDDLE", "RIGHT"
  row            Int                   // 1 to 3
  col            Int                   // 1 to 4
  ownerId        String?
  owner          User?                 @relation("OwnerParkingSpots", fields: [ownerId], references: [id], onDelete: SetNull)
  approved       Boolean               @default(false)
  priceHourly    Float                 @default(50)
  priceDaily     Float                 @default(100)
  priceWeekly     Float                 @default(500)
  priceMonthly   Float                 @default(1000)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  availabilities ParkingAvailability[]
  bookings       ParkingBooking[]
}

model ParkingAvailability {
  id             String          @id @default(uuid())
  spotId         String
  spot           ParkingSpot     @relation(fields: [spotId], references: [id], onDelete: Cascade)
  date           String          // e.g. "2026-05-22"
  slotType       ParkingSlotType @default(HOURLY)
  startTime      DateTime
  endTime        DateTime
  price          Float
  isBooked       Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  bookings       ParkingBooking[]
}

model ParkingBooking {
  id             String              @id @default(uuid())
  spotId         String
  spot           ParkingSpot         @relation(fields: [spotId], references: [id], onDelete: Cascade)
  availabilityId String?
  availability   ParkingAvailability? @relation(fields: [availabilityId], references: [id], onDelete: SetNull)
  userId         String
  user           User                @relation("UserParkingBookings", fields: [userId], references: [id], onDelete: Cascade)
  date           String              // "2026-05-22"
  slotType       ParkingSlotType
  startTime      DateTime
  endTime        DateTime
  price          Float
  status         BookingStatus       @default(REQUESTED)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

model Vehicle {
  id            String   @id @default(uuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  vehicleNumber String
  type          String   // "CAR" | "BIKE"
  capacity      Int      // 2 | 5 | 7
  fuelType      String   // "CNG" | "Petrol" | "Diesel"
}

model VerificationCode {
  id          String   @id @default(uuid())
  phoneNumber String
  code        String
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([phoneNumber])
}

model PendingNotification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  payload   String   // JSON stringified payload
  createdAt DateTime @default(now())

  @@index([userId])
}

model BuddyRequest {
  id             String   @id @default(uuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  riderId        String
  rider          User     @relation("RiderBuddyRequests", fields: [riderId], references: [id], onDelete: Cascade)

  startPlaceName String
  endPlaceName   String
  startTime      DateTime

  startPoint     Unsupported("geometry(Point,4326)")?
  endPoint       Unsupported("geometry(Point,4326)")?

  seatsNeeded    Int      @default(1)
  status         String   @default("OPEN") // "OPEN" | "ACCEPTED" | "CANCELLED"
}
